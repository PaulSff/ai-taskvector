{
  "environment_type": "rag",
  "environments": ["canonical"],
  "units": [
    {
      "id": "inject_msg",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "name": null,
      "input_ports": [
        {
          "name": "template",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "data",
          "type": "Any"
        }
      ]
    },
    {
      "id": "clean_text",
      "type": "CleanText",
      "controllable": false,
      "params": {
        "symbol_density_threshold": 0.25,
        "min_block_len": 4,
        "max_chars": 1200
      },
      "input_ports": [{ "name": "text", "type": "str" }],
      "output_ports": [
        { "name": "text", "type": "str" },
        { "name": "error", "type": "str" }
      ]
    },
    {
      "id": "language_detector",
      "type": "LanguageDetector",
      "controllable": false,
      "params": {
        "languages": "all",
        "default_when_unknown": "en"
      },
      "input_ports": [{ "name": "text", "type": "str" }],
      "output_ports": [
        { "name": "iso639_1", "type": "str" },
        { "name": "confidence", "type": "float" },
        { "name": "language", "type": "str" },
        { "name": "reliable", "type": "Any" },
        { "name": "error", "type": "str" }
      ]
    },
    {
      "id": "merge_llm",
      "type": "Aggregate",
      "controllable": false,
      "params": {
        "num_inputs": 2,
        "keys": ["user_message", "language"]
      },
      "input_ports": [
        { "name": "in_0", "type": "Any" },
        { "name": "in_1", "type": "Any" }
      ],
      "output_ports": [
        { "name": "data", "type": "Any" },
        { "name": "error", "type": "str" }
      ]
    },
    {
      "id": "dispatcher",
      "type": "LLMAgent",
      "controllable": false,
      "params": {
        "host": "role.dispatcher.llm.ollama_host",
        "model_name": "role.dispatcher.llm.ollama_model",
        "provider": "role.dispatcher.llm.provider",
        "options": "role.dispatcher.llm.generation_options"
      },
      "name": null,
      "input_ports": [
        {
          "name": "system_prompt",
          "type": "str"
        },
        {
          "name": "user_message",
          "type": "str"
        }
      ],
      "output_ports": [
        {
          "name": "action",
          "type": "Any"
        },
        {
          "name": "error",
          "type": "str"
        }
      ]
    },
    {
      "id": "llm_parser",
      "type": "ProcessAgent",
      "controllable": false,
      "params": {},
      "name": null,
      "input_ports": [
        {
          "name": "action",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "edits",
          "type": "Any"
        },
        {
          "name": "error",
          "type": "str"
        }
      ]
    },
    {
      "id": "delegate_req",
      "type": "delegate_request",
      "controllable": false,
      "params": {},
      "name": null,
      "input_ports": [
        {
          "name": "action",
          "type": "Any"
        },
        {
          "name": "parser_output",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "data",
          "type": "Any"
        },
        {
          "name": "error",
          "type": "str"
        }
      ]
    },
    {
      "id": "prompt_llm",
      "type": "Prompt",
      "controllable": false,
      "params": {
        "template_path": "config/prompts/dispatcher.json"
      },
      "name": null,
      "input_ports": [
        {
          "name": "data",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "system_prompt",
          "type": "str"
        },
        {
          "name": "user_message",
          "type": "str"
        }
      ]
    }
  ],
  "connections": [
    {
      "from": "dispatcher",
      "to": "llm_parser",
      "from_port": "0",
      "to_port": "0",
      "connection_type": null
    },
    {
      "from": "inject_msg",
      "to": "merge_llm",
      "from_port": "0",
      "to_port": "0",
      "connection_type": null
    },
    {
      "from": "inject_msg",
      "to": "clean_text",
      "from_port": "0",
      "to_port": "0",
      "connection_type": null
    },
    {
      "from": "clean_text",
      "to": "language_detector",
      "from_port": "0",
      "to_port": "0",
      "connection_type": null
    },
    {
      "from": "language_detector",
      "to": "merge_llm",
      "from_port": "2",
      "to_port": "1",
      "connection_type": null
    },
    {
      "from": "llm_parser",
      "to": "delegate_req",
      "from_port": "0",
      "to_port": "1",
      "connection_type": null
    },
    {
      "from": "merge_llm",
      "to": "prompt_llm",
      "from_port": "0",
      "to_port": "0",
      "connection_type": null
    },
    {
      "from": "prompt_llm",
      "to": "dispatcher",
      "from_port": "0",
      "to_port": "0",
      "connection_type": null
    },
    {
      "from": "prompt_llm",
      "to": "dispatcher",
      "from_port": "1",
      "to_port": "1",
      "connection_type": null
    }
  ],
  "code_blocks": [],
  "layout": null,
  "origin": {
    "canonical": true,
    "node_red": null,
    "pyflow": null,
    "n8n": null,
    "ryven": null,
    "comfyui": null
  },
  "origin_format": "dict",
  "runtime": "native",
  "tabs": null,
  "metadata": {
    "description": "Auto-delegation workflow: LLM (dispatcher) analyses a user's message to hand the conversation over to a suitable role. Chat runs the workflow when auto_delegation_is_allowed and consumes delegate_request.data to pick up an appropriate role to continue the conversation with. The user's language is detected during the execution, so the follow-up message comes out translated."
  }
}
