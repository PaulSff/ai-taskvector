{
  "units": [
    {
      "id": "inject_send_message",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "input_ports": [],
      "output_ports": [{ "name": "data", "type": "Any" }]
    },
    {
      "id": "tg_send_message",
      "type": "TelegramBot",
      "controllable": false,
      "params": {
        "_needs_executor": true,
        "bot_token": "tool.get_chats.telegram.bot_token",
        "wait_for_delivery": true,
        "delivery_timeout_s": 60,
        "zmq_sub_endpoint": "tool.send_message.mq.zmq_sub_endpoint",
        "update_endpoint": "tool.send_message.mq.zmq_update_endpoint",
        "response_endpoint": "tool.send_message.mq.zmq_response_endpoint",
        "workflow_path": "tool.send_message.workflow"
      },
      "input_ports": [
        { "name": "tg_start", "type": "Any" },
        { "name": "tg_stop", "type": "Any" },
        { "name": "get_unread", "type": "Any" },
        { "name": "send_message", "type": "Any" },
        { "name": "raw", "type": "Any" }
      ],
      "output_ports": [
        { "name": "update", "type": "Any" },
        { "name": "status", "type": "Any" },
        { "name": "error", "type": "Any" }
      ]
    }
  ],
  "connections": [
    {
      "from": "inject_send_message",
      "to": "tg_send_message",
      "from_port": "0",
      "to_port": "3"
    }
  ],
  "metadata": {
    "description": "Send a chat message via messenger (TelegramClient). Inject payload with action send_message, messenger (e.g. telegram), chat_id, and message → tg_send_message send_message port."
  }
}
