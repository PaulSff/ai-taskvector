{
  "environment_type": "data_bi",
  "environments": ["canonical"],
  "units": [
    {
      "id": "inject_path",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "name": null,
      "input_ports": [
        {
          "name": "template",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "data",
          "type": "Any"
        }
      ]
    },
    {
      "id": "plain_extract",
      "type": "PlainTextExtract",
      "controllable": false,
      "params": {
        "origin": "external-upload",
        "content_type": "plain-text-generic"
      },
      "input_ports": [
        { "name": "data", "type": "Any" },
        { "name": "file_path", "type": "Any" }
      ],
      "output_ports": [
        { "name": "items", "type": "Any" },
        { "name": "error", "type": "str" }
      ]
    },
    {
      "id": "prompt",
      "type": "Prompt",
      "controllable": false,
      "params": {
        "template": "Source:\n{items}\n\nFrom:\n{file_path}"
      },
      "name": null,
      "input_ports": [
        {
          "name": "data",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "system_prompt",
          "type": "str"
        },
        {
          "name": "user_message",
          "type": "str"
        }
      ]
    },
    {
      "id": "merge",
      "type": "Aggregate",
      "controllable": false,
      "params": {
        "num_inputs": 2,
        "keys": ["items", "file_path"]
      },
      "name": null,
      "input_ports": [
        {
          "name": "data",
          "type": "Any"
        },
        {
          "name": "in_0",
          "type": "Any"
        },
        {
          "name": "in_1",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "data",
          "type": "Any"
        },
        {
          "name": "error",
          "type": "str"
        }
      ]
    }
  ],
  "connections": [
    {
      "from": "inject_path",
      "to": "plain_extract",
      "from_port": "0",
      "to_port": "0",
      "connection_type": null
    },
    {
      "from": "inject_path",
      "to": "merge",
      "from_port": "0",
      "to_port": "2",
      "connection_type": null
    },
    {
      "from": "plain_extract",
      "to": "merge",
      "from_port": "0",
      "to_port": "1",
      "connection_type": null
    },
    {
      "from": "merge",
      "to": "prompt",
      "from_port": "0",
      "to_port": "0",
      "connection_type": null
    }
  ],
  "code_blocks": [],
  "layout": null,
  "origin_format": "dict",
  "runtime": "native",
  "tabs": null,
  "metadata": {
    "description": "Read plain text tool subflow: This workflow extracts content from a UTF-8 file and provides a structured output for further analysis: str - items."
  },
  "todo_list": null
}
