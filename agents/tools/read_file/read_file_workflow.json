{
  "units": [
    {
      "id": "fetch_source",
      "type": "FetchSource",
      "controllable": false,
      "params": {
        "save_dir": "settings.rag_downloads_dir",
        "overwrite": false
      },
      "input_ports": [
        {
          "name": "source",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "file_path",
          "type": "str"
        },
        {
          "name": "source",
          "type": "str"
        },
        {
          "name": "fetched",
          "type": "Any"
        },
        {
          "name": "error",
          "type": "str"
        }
      ]
    },
    {
      "id": "inject_path",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "input_ports": [
        {
          "name": "template",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "data",
          "type": "Any"
        }
      ]
    },
    {
      "id": "detect",
      "type": "FileTypeDetector",
      "controllable": false,
      "params": {},
      "input_ports": [
        {
          "name": "data",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "content_type_id",
          "type": "str"
        },
        {
          "name": "content_kind",
          "type": "str"
        },
        {
          "name": "family",
          "type": "str"
        },
        {
          "name": "suffix",
          "type": "str"
        },
        {
          "name": "payload",
          "type": "Any"
        },
        {
          "name": "parsed",
          "type": "Any"
        },
        {
          "name": "error",
          "type": "str"
        }
      ]
    },
    {
      "id": "pt_run",
      "type": "PayloadTransform",
      "controllable": false,
      "params": {
        "routes": [
          {
            "any": [
              {
                "field": "suffix",
                "ends_with": ".json"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "agents/tools/read_file/read_json_subflow.json",
                "initial_inputs": {
                  "inject_path": {
                    "data": "{file_path}"
                  }
                }
              }
            }
          },
          {
            "any": [
              {
                "field": "suffix",
                "ends_with": ".yaml"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "agents/tools/read_file/read_json_subflow.json",
                "initial_inputs": {
                  "inject_path": {
                    "data": "{file_path}"
                  }
                }
              }
            }
          },
          {
            "any": [
              {
                "field": "suffix",
                "ends_with": ".yml"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "agents/tools/read_file/read_json_subflow.json",
                "initial_inputs": {
                  "inject_path": {
                    "data": "{file_path}"
                  }
                }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "html-generic"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/html/html-generic/html_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "pdf-generic"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "agents/tools/read_file/read_pdf_subflow.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              { "field": "content_type_id", "equals_str": "word-generic" }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "agents/tools/read_file/read_word_subflow.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "spreadsheet-generic"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "agents/tools/read_file/read_spreadsheet_subflow.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "presentation-generic"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "agents/tools/read_file/read_presentation_subflow.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "markdown-generic"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "agents/tools/read_file/read_markdown_subflow.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-content-type-readme"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "agents/tools/read_file/read_markdown_subflow.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-docs"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "agents/tools/read_file/read_markdown_subflow.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-rag-readme"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "agents/tools/read_file/read_markdown_subflow.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-role-readme"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "agents/tools/read_file/read_markdown_subflow.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-tool-readme"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "agents/tools/read_file/read_markdown_subflow.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-unit-readme"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "agents/tools/read_file/read_markdown_subflow.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "plain-text-generic"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "agents/tools/read_file/read_plain_text_subflow.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-content-type-config"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/plain-text/taskvector-content-type-config/content_type_config.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-rag-config"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/plain-text/taskvector-rag-config/rag_config_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-role-config"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/plain-text/taskvector-role-config/role_config_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-tool-config"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/plain-text/taskvector-tool-config/tool_config_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-role-source"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "agents/tools/read_file/read_plain_text_subflow.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-tool-source"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "agents/tools/read_file/read_plain_text_subflow.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-unit-source"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "agents/tools/read_file/read_plain_text_subflow.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-content-type-source"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "agents/tools/read_file/read_plain_text_subflow.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "default": true,
            "parser_output": {}
          }
        ]
      },
      "input_ports": [
        {
          "name": "data",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "parser_output",
          "type": "Any"
        }
      ]
    },
    {
      "id": "rw_run",
      "type": "RunWorkflow",
      "controllable": false,
      "params": {
        "_needs_executor": true
      },
      "input_ports": [
        {
          "name": "parser_output",
          "type": "Any"
        },
        {
          "name": "graph",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "data",
          "type": "Any"
        },
        {
          "name": "error",
          "type": "str"
        }
      ]
    }
  ],
  "connections": [
    {
      "from": "inject_path",
      "to": "fetch_source",
      "from_port": "0",
      "to_port": "0"
    },
    {
      "from": "fetch_source",
      "to": "detect",
      "from_port": "0",
      "to_port": "0"
    },
    {
      "from": "detect",
      "to": "pt_run",
      "from_port": "4",
      "to_port": "0"
    },
    {
      "from": "pt_run",
      "to": "rw_run",
      "from_port": "0",
      "to_port": "0"
    }
  ],
  "metadata": {
    "description": "TaskVector RAG Upload workflow - the main upload workflow, which takes a file on import for its classificaton, content extraction, chunking, embeddeding and getting indexed on ChromaDB. Content gets extracted by extraction subflows, depending on the file_type detected. The subflows as well as discriminants are part of the content_type packages. The routes are defined in the PayloadTransform params."
  }
}
