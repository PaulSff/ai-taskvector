{
  "environment_type": "canonical",
  "environments": ["canonical"],
  "units": [
    {
      "id": "inject_context",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "input_ports": [{ "name": "data", "type": "Any" }],
      "output_ports": [{ "name": "data", "type": "Any" }]
    },
    {
      "id": "build_dispatch_payload",
      "type": "PayloadTransform",
      "controllable": false,
      "params": {
        "routes": [
          {
            "all": [{ "field": "auto_delegation_is_allowed", "equals": true }],
            "parser_output": {
              "run_workflow": {
                "path": "{auto_delegate_workflow_path}",
                "initial_inputs": {
                  "inject_msg": {
                    "data": { "user_message": "{user_message}" }
                  }
                }
              }
            }
          },
          {
            "default": true,
            "parser_output": {}
          }
        ]
      },
      "input_ports": [{ "name": "data", "type": "Any" }],
      "output_ports": [{ "name": "parser_output", "type": "Any" }]
    },
    {
      "id": "run_dispatcher",
      "type": "RunWorkflow",
      "controllable": false,
      "params": {
        "_needs_executor": true
      },
      "input_ports": [
        { "name": "parser_output", "type": "Any" },
        { "name": "graph", "type": "Any" }
      ],
      "output_ports": [
        { "name": "data", "type": "Any" },
        { "name": "error", "type": "str" }
      ]
    },
    {
      "id": "merge_dispatch",
      "type": "Aggregate",
      "controllable": false,
      "params": {
        "num_inputs": 2,
        "keys": ["dispatcher_out", "context"]
      },
      "input_ports": [
        { "name": "data", "type": "Any" },
        { "name": "in_0", "type": "Any" },
        { "name": "in_1", "type": "Any" }
      ],
      "output_ports": [
        { "name": "data", "type": "Any" },
        { "name": "error", "type": "str" }
      ]
    },
    {
      "id": "resolve_role",
      "type": "PayloadTransform",
      "controllable": false,
      "params": {
        "routes": [
          {
            "comment": "Dispatcher returned a valid role — rebuild full context with role_id overridden.",
            "all": [
              { "field": "context.auto_delegation_is_allowed", "equals": true },
              {
                "field": "dispatcher_out.delegate_req.data.ok",
                "equals": true
              },
              {
                "field": "dispatcher_out.delegate_req.data.delegate_to",
                "regex": "(?i)^(?!none$).+"
              }
            ],
            "parser_output": {
              "user_message": { "_raw": "context.user_message" },
              "messenger": { "_raw": "context.messenger" },
              "role_id": "{dispatcher_out.delegate_req.data.delegate_to}",
              "history": { "_raw": "context.history" },
              "session_language": { "_raw": "context.session_language" },
              "last_apply_result": { "_raw": "context.last_apply_result" },
              "graph": { "_raw": "context.graph" },
              "recent_changes": { "_raw": "context.recent_changes" },
              "use_current_graph": { "_raw": "context.use_current_graph" },
              "provider": { "_raw": "context.provider" },
              "cfg": { "_raw": "context.cfg" },
              "rag_index_dir": { "_raw": "context.rag_index_dir" },
              "rag_embedding_model": { "_raw": "context.rag_embedding_model" },
              "mydata_dir": { "_raw": "context.mydata_dir" },
              "coding_is_allowed": { "_raw": "context.coding_is_allowed" },
              "contribution_is_allowed": {
                "_raw": "context.contribution_is_allowed"
              },
              "training_config_path": {
                "_raw": "context.training_config_path"
              },
              "auto_delegation_is_allowed": {
                "_raw": "context.auto_delegation_is_allowed"
              },
              "auto_delegate_workflow_path": {
                "_raw": "context.auto_delegate_workflow_path"
              }
            }
          },
          {
            "comment": "No delegation (disabled, skipped, or same role) — pass context through unchanged.",
            "default": true,
            "parser_output": { "_raw": "context" }
          }
        ]
      },
      "input_ports": [{ "name": "data", "type": "Any" }],
      "output_ports": [{ "name": "parser_output", "type": "Any" }]
    },
    {
      "id": "orchestrator",
      "type": "AgentOrchestrator",
      "controllable": false,
      "params": {
        "_needs_executor": true,
        "timeout_s": 90
      },
      "input_ports": [
        { "name": "data", "type": "Any" },
        { "name": "messenger", "type": "str" }
      ],
      "output_ports": [
        { "name": "status", "type": "Any" },
        { "name": "token", "type": "Any" },
        { "name": "message", "type": "Any" },
        { "name": "role", "type": "Any" },
        { "name": "error", "type": "Any" }
      ]
    },
    {
      "id": "extract_graph_for_save",
      "type": "PayloadTransform",
      "controllable": false,
      "params": {
        "routes": [
          {
            "default": true,
            "parser_output": "{message.graph}"
          }
        ]
      },
      "name": null,
      "input_ports": [
        {
          "name": "data",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "parser_output",
          "type": "Any"
        }
      ]
    },
    {
      "id": "save_final_graph",
      "type": "SaveWorkflow",
      "controllable": false,
      "params": {
        "format": "json"
      },
      "name": null,
      "input_ports": [
        {
          "name": "graph",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "saved_at",
          "type": "Any"
        },
        {
          "name": "error",
          "type": "Any"
        }
      ]
    },
    {
      "id": "debug_orchestrator_msg",
      "type": "Debug",
      "controllable": true,
      "params": {
        "log_path": "orchestrator_msg.log"
      },
      "name": null,
      "input_ports": [
        {
          "name": "data",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "data",
          "type": "Any"
        },
        {
          "name": "error",
          "type": "str"
        }
      ]
    },
    {
      "id": "debug_save_output",
      "type": "Debug",
      "controllable": true,
      "params": {
        "log_path": "workflow_save.log"
      },
      "name": null,
      "input_ports": [
        {
          "name": "data",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "data",
          "type": "Any"
        },
        {
          "name": "error",
          "type": "str"
        }
      ]
    }
  ],
  "connections": [
    {
      "comment": "inject_context.data → build_dispatch_payload.data",
      "from": "inject_context",
      "to": "build_dispatch_payload",
      "from_port": "0",
      "to_port": "0"
    },
    {
      "comment": "build_dispatch_payload.parser_output → run_dispatcher.parser_output",
      "from": "build_dispatch_payload",
      "to": "run_dispatcher",
      "from_port": "0",
      "to_port": "0"
    },
    {
      "comment": "run_dispatcher.data → merge_dispatch.in_0 (key: dispatcher_out)",
      "from": "run_dispatcher",
      "to": "merge_dispatch",
      "from_port": "0",
      "to_port": "1"
    },
    {
      "comment": "inject_context.data → merge_dispatch.in_1 (key: context)",
      "from": "inject_context",
      "to": "merge_dispatch",
      "from_port": "0",
      "to_port": "2"
    },
    {
      "comment": "merge_dispatch.data → resolve_role.data",
      "from": "merge_dispatch",
      "to": "resolve_role",
      "from_port": "0",
      "to_port": "0"
    },
    {
      "comment": "resolve_role.parser_output → orchestrator.data (complete resolved context)",
      "from": "resolve_role",
      "to": "orchestrator",
      "from_port": "0",
      "to_port": "0"
    },
    {
      "from": "orchestrator",
      "to": "extract_graph_for_save",
      "from_port": "2",
      "to_port": "0",
      "connection_type": null
    },
    {
      "from": "extract_graph_for_save",
      "to": "save_final_graph",
      "from_port": "0",
      "to_port": "0",
      "connection_type": null
    },
    {
      "from": "orchestrator",
      "to": "debug_orchestrator_msg",
      "from_port": "2",
      "to_port": "0",
      "connection_type": null
    },
    {
      "from": "save_final_graph",
      "to": "debug_save_output",
      "from_port": "0",
      "to_port": "0",
      "connection_type": null
    }
  ],
  "origin_format": "dict",
  "runtime": "native",
  "metadata": {
    "description": "Messenger-agnostic chat orchestration pipeline. Wraps the full dispatcher → role-resolver → agent-turn chain as a reusable pipeline type"
  }
}
