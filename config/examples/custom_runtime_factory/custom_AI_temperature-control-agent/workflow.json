{
  "environment_type": "thermodynamic",
  "units": [
    {"id": "hot_source", "type": "Source", "controllable": false, "params": {"temp": 60.0, "max_flow": 1.0}},
    {"id": "cold_source", "type": "Source", "controllable": false, "params": {"temp": 10.0, "max_flow": 1.0}},
    {"id": "mixer_tank", "type": "Tank", "controllable": false, "params": {"capacity": 1.0, "cooling_rate": 0.01}},
    {"id": "hot_valve", "type": "Valve", "controllable": true, "params": {}},
    {"id": "cold_valve", "type": "Valve", "controllable": true, "params": {}},
    {"id": "dump_valve", "type": "Valve", "controllable": true, "params": {}},
    {"id": "thermometer_hot", "type": "Sensor", "controllable": false, "params": {"measure": "temperature"}},
    {"id": "thermometer_cold", "type": "Sensor", "controllable": false, "params": {"measure": "temperature"}},
    {"id": "thermometer_tank", "type": "Sensor", "controllable": false, "params": {"measure": "temperature"}},
    {"id": "water_level", "type": "Sensor", "controllable": false, "params": {"measure": "volume"}},
    {"id": "collector", "type": "Join", "controllable": false, "params": {"num_inputs": 4}},
    {"id": "switch", "type": "Switch", "controllable": false, "params": {"num_outputs": 3}},
    {"id": "step_driver", "type": "StepDriver", "controllable": false, "params": {}},
    {"id": "split", "type": "Split", "controllable": false, "params": {"num_outputs": 3}},
    {"id": "step_rewards", "type": "StepRewards", "controllable": false, "params": {"max_steps": 600}},
    {"id": "rl_agent", "type": "RLAgent", "controllable": false, "name": "AI Operator", "params": {"observation_source_ids": ["thermometer_cold", "thermometer_hot", "thermometer_tank", "water_level"], "action_target_ids": ["cold_valve", "dump_valve", "hot_valve"], "model_path": "models/custom_AI_temperature-control-agent/best_model.zip"}},
    {"id": "random_hot", "type": "Random", "controllable": false, "params": {"min": -2.0, "max": 2.0, "size": 1}},
    {"id": "random_cold", "type": "Random", "controllable": false, "params": {"min": -2.0, "max": 2.0, "size": 1}}
  ],
  "connections": [
    {"from": "hot_source", "to": "thermometer_hot", "from_port": "0", "to_port": "0"},
    {"from": "hot_valve", "to": "mixer_tank", "from_port": "0", "to_port": "0"},
    {"from": "hot_source", "to": "mixer_tank", "from_port": "0", "to_port": "3"},
    {"from": "cold_source", "to": "thermometer_cold", "from_port": "0", "to_port": "0"},
    {"from": "cold_valve", "to": "mixer_tank", "from_port": "0", "to_port": "1"},
    {"from": "cold_source", "to": "mixer_tank", "from_port": "0", "to_port": "4"},
    {"from": "dump_valve", "to": "mixer_tank", "from_port": "0", "to_port": "2"},
    {"from": "mixer_tank", "to": "thermometer_tank", "from_port": "0", "to_port": "0"},
    {"from": "mixer_tank", "to": "water_level", "from_port": "2", "to_port": "0"},
    {"from": "thermometer_cold", "to": "collector", "from_port": "0", "to_port": "0"},
    {"from": "thermometer_hot", "to": "collector", "from_port": "0", "to_port": "1"},
    {"from": "thermometer_tank", "to": "collector", "from_port": "0", "to_port": "2"},
    {"from": "water_level", "to": "collector", "from_port": "0", "to_port": "3"},
    {"from": "collector", "to": "step_rewards", "from_port": "0", "to_port": "0"},
    {"from": "step_driver", "to": "step_rewards", "from_port": "2", "to_port": "1"},
    {"from": "collector", "to": "rl_agent", "from_port": "0", "to_port": "0"},
    {"from": "rl_agent", "to": "switch", "from_port": "0", "to_port": "0"},
    {"from": "switch", "to": "cold_valve", "from_port": "0", "to_port": "0"},
    {"from": "switch", "to": "dump_valve", "from_port": "1", "to_port": "0"},
    {"from": "switch", "to": "hot_valve", "from_port": "2", "to_port": "0"},
    {"from": "step_driver", "to": "split", "from_port": "0", "to_port": "0"},
    {"from": "split", "to": "random_cold", "from_port": "0", "to_port": "0"},
    {"from": "split", "to": "random_hot", "from_port": "1", "to_port": "0"},
    {"from": "random_cold", "to": "cold_source", "from_port": "0", "to_port": "1"},
    {"from": "random_hot", "to": "hot_source", "from_port": "0", "to_port": "1"},
    {"from": "split", "to": "mixer_tank", "from_port": "2", "to_port": "5"}
  ]
}
