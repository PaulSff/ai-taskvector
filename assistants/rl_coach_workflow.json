{
  "environment_type": "data_bi",
  "environments": ["canonical", "data_bi"],
  "units": [
    {
      "id": "inject_user_message",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "input_ports": [{"name": "data", "type": "Any"}],
      "output_ports": [{"name": "data", "type": "Any"}]
    },
    {
      "id": "inject_training_config",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "input_ports": [],
      "output_ports": [{"name": "data", "type": "Any"}]
    },
    {
      "id": "inject_training_results",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "input_ports": [],
      "output_ports": [{"name": "data", "type": "Any"}]
    },
    {
      "id": "inject_previous_turn",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "input_ports": [],
      "output_ports": [{"name": "data", "type": "Any"}]
    },
    {
      "id": "inject_training_config_dict",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "input_ports": [],
      "output_ports": [{"name": "data", "type": "Any"}]
    },
    {
      "id": "rag_search",
      "type": "RagSearch",
      "controllable": false,
      "params": {
        "persist_dir": "{settings}",
        "embedding_model": "{settings}",
        "top_k": 10
      },
      "input_ports": [
        {"name": "query", "type": "str"},
        {"name": "edits", "type": "Any"}
      ],
      "output_ports": [{"name": "table", "type": "Any"}]
    },
    {
      "id": "rag_filter",
      "type": "Filter",
      "controllable": false,
      "params": {
        "column": "score",
        "op": "ge",
        "value": 0.48
      },
      "input_ports": [
        {"name": "value", "type": "float"},
        {"name": "table", "type": "table"},
        {"name": "column", "type": "str"},
        {"name": "op", "type": "str"}
      ],
      "output_ports": [
        {"name": "row_count", "type": "float"},
        {"name": "table", "type": "table"}
      ]
    },
    {
      "id": "format_rag",
      "type": "FormatRagPrompt",
      "controllable": false,
      "params": {
        "max_chars": 1200,
        "snippet_max": 400
      },
      "input_ports": [{"name": "table", "type": "Any"}],
      "output_ports": [{"name": "data", "type": "str"}]
    },
    {
      "id": "merge_llm",
      "type": "Aggregate",
      "controllable": false,
      "params": {
        "num_inputs": 5,
        "keys": [
          "user_message",
          "rag_context",
          "training_config",
          "training_results",
          "previous_turn"
        ],
        "required_keys": ["user_message"]
      },
      "input_ports": [
        {"name": "in_0", "type": "Any"},
        {"name": "in_1", "type": "Any"},
        {"name": "in_2", "type": "Any"},
        {"name": "in_3", "type": "Any"},
        {"name": "in_4", "type": "Any"}
      ],
      "output_ports": [
        {"name": "data", "type": "Any"},
        {"name": "error", "type": "str"}
      ]
    },
    {
      "id": "prompt_llm",
      "type": "Prompt",
      "controllable": false,
      "params": {"template_path": "{settings}"},
      "input_ports": [{"name": "data", "type": "Any"}],
      "output_ports": [
        {"name": "system_prompt", "type": "str"},
        {"name": "user_message", "type": "str"}
      ]
    },
    {
      "id": "llm_agent",
      "type": "LLMAgent",
      "controllable": false,
      "params": {
        "host": "{settings}",
        "model_name": "{settings}",
        "provider": "{settings}",
        "options": "{settings}"
      },
      "input_ports": [
        {"name": "system_prompt", "type": "str"},
        {"name": "user_message", "type": "str"}
      ],
      "output_ports": [
        {"name": "action", "type": "Any"},
        {"name": "error", "type": "str"}
      ]
    },
    {
      "id": "parser",
      "type": "TrainingConfigParser",
      "controllable": false,
      "params": {},
      "input_ports": [{"name": "action", "type": "Any"}],
      "output_ports": [
        {"name": "edits", "type": "Any"},
        {"name": "error", "type": "str"}
      ]
    },
    {
      "id": "process",
      "type": "ApplyTrainingConfigEdits",
      "controllable": false,
      "params": {},
      "input_ports": [
        {"name": "training_config", "type": "Any"},
        {"name": "edits", "type": "Any"}
      ],
      "output_ports": [
        {"name": "result", "type": "Any"},
        {"name": "status", "type": "Any"},
        {"name": "config", "type": "Any"},
        {"name": "error", "type": "str"}
      ]
    }
  ],
  "connections": [
    { "from": "inject_user_message", "to": "merge_llm", "from_port": "0", "to_port": "0" },
    { "from": "inject_user_message", "to": "rag_search", "from_port": "0", "to_port": "0" },
    { "from": "rag_search", "to": "rag_filter", "from_port": "0", "to_port": "1" },
    { "from": "rag_filter", "to": "format_rag", "from_port": "1", "to_port": "0" },
    { "from": "format_rag", "to": "merge_llm", "from_port": "0", "to_port": "1" },
    { "from": "inject_training_config", "to": "merge_llm", "from_port": "0", "to_port": "2" },
    { "from": "inject_training_results", "to": "merge_llm", "from_port": "0", "to_port": "3" },
    { "from": "inject_previous_turn", "to": "merge_llm", "from_port": "0", "to_port": "4" },
    { "from": "merge_llm", "to": "prompt_llm", "from_port": "0", "to_port": "0" },
    { "from": "prompt_llm", "to": "llm_agent", "from_port": "0", "to_port": "0" },
    { "from": "prompt_llm", "to": "llm_agent", "from_port": "1", "to_port": "1" },
    { "from": "llm_agent", "to": "parser", "from_port": "0", "to_port": "0" },
    { "from": "inject_training_config_dict", "to": "process", "from_port": "0", "to_port": "0" },
    { "from": "parser", "to": "process", "from_port": "0", "to_port": "1" }
  ],
  "layout": {
    "inject_user_message": {"x": 80, "y": 120},
    "inject_training_config": {"x": 80, "y": 200},
    "inject_training_results": {"x": 80, "y": 280},
    "inject_previous_turn": {"x": 80, "y": 360},
    "rag_search": {"x": 320, "y": 80},
    "rag_filter": {"x": 520, "y": 80},
    "format_rag": {"x": 720, "y": 80},
    "merge_llm": {"x": 400, "y": 280},
    "prompt_llm": {"x": 640, "y": 280},
    "llm_agent": {"x": 880, "y": 280},
    "inject_training_config_dict": {"x": 80, "y": 440},
    "parser": {"x": 1080, "y": 280},
    "process": {"x": 1280, "y": 280}
  },
  "metadata": {
    "description": "RL Coach assistant: helps users configure RL training (goals, rewards, algorithm, hyperparameters). User message → RagSearch → Filter → FormatRagPrompt; injects (config summary, training results, previous turn, config dict) → Aggregate → Prompt → LLMAgent → TrainingConfigParser → ApplyTrainingConfigEdits. Used by Flet chat via run_rl_coach_workflow()."
  },
