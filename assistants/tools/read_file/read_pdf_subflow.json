{
  "environment_type": "data_bi",
  "environments": ["canonical"],
  "units": [
    {
      "id": "inject_path",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "name": null,
      "input_ports": [
        {
          "name": "template",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "data",
          "type": "Any"
        }
      ]
    },
    {
      "id": "load_doc",
      "type": "LoadDocument",
      "controllable": false,
      "params": {
        "include_pictures": "settings.rag_include_pictures",
        "images_scale": "settings.rag_images_scale",
        "do_picture_classification": "settings.rag_picture_classification",
        "do_picture_description": "settings.rag_picture_description",
        "picture_description_model": "settings.rag_picture_description_model",
        "picture_description_api_url": "settings.rag_picture_description_api_url",
        "do_code_enrichment": "settings.rag_code_enrichment",
        "do_formula_enrichment": "settings.rag_formula_enrichment"
      },
      "name": null,
      "input_ports": [
        {
          "name": "path",
          "type": "str"
        }
      ],
      "output_ports": [
        {
          "name": "body_text",
          "type": "str"
        },
        {
          "name": "markdown",
          "type": "str"
        },
        {
          "name": "html",
          "type": "str"
        },
        {
          "name": "doctags",
          "type": "str"
        },
        {
          "name": "json_doc",
          "type": "Any"
        },
        {
          "name": "tables",
          "type": "Any"
        },
        {
          "name": "pictures",
          "type": "Any"
        },
        {
          "name": "headings",
          "type": "Any"
        },
        {
          "name": "furniture",
          "type": "Any"
        },
        {
          "name": "key_value_items",
          "type": "Any"
        },
        {
          "name": "page_count",
          "type": "float"
        },
        {
          "name": "error",
          "type": "str"
        }
      ]
    },
    {
      "id": "prompt",
      "type": "Prompt",
      "controllable": false,
      "params": {
        "template": "Parsed:\n{json_doc},\n\nFrom:\n{file_path}"
      },
      "name": null,
      "input_ports": [
        {
          "name": "data",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "system_prompt",
          "type": "str"
        },
        {
          "name": "user_message",
          "type": "str"
        }
      ]
    },
    {
      "id": "merge",
      "type": "Aggregate",
      "controllable": false,
      "params": {
        "num_inputs": 2,
        "keys": ["file_path", "json_doc"]
      },
      "name": null,
      "input_ports": [
        {
          "name": "data",
          "type": "Any"
        },
        {
          "name": "in_0",
          "type": "Any"
        },
        {
          "name": "in_1",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "data",
          "type": "Any"
        },
        {
          "name": "error",
          "type": "str"
        }
      ]
    }
  ],
  "connections": [
    {
      "from": "inject_path",
      "to": "load_doc",
      "from_port": "0",
      "to_port": "0",
      "connection_type": null
    },
    {
      "from": "inject_path",
      "to": "merge",
      "from_port": "0",
      "to_port": "1",
      "connection_type": null
    },
    {
      "from": "load_doc",
      "to": "merge",
      "from_port": "4",
      "to_port": "2",
      "connection_type": null
    },
    {
      "from": "merge",
      "to": "prompt",
      "from_port": "0",
      "to_port": "0",
      "connection_type": null
    }
  ],
  "code_blocks": [],
  "layout": null,
  "origin_format": "dict",
  "runtime": "native",
  "tabs": null,
  "metadata": {
    "description": "Read PDF documnent tool subflow: This workflow extracts content from a PDF document (.pdf) via Docling and provides a structured output for further analysis: str - json_doc (docling document), file_path."
  },
  "todo_list": null
}
