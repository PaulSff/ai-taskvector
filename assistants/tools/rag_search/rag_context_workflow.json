{
  "units": [
    {
      "id": "rag_search",
      "type": "RagSearch",
      "controllable": false,
      "params": {
        "persist_dir": "settings.rag_index_data_dir",
        "embedding_model": "settings.rag_embedding_model",
        "top_k": 10
      },
      "input_ports": [
        {"name": "query", "type": "str"},
        {"name": "edits", "type": "Any"},
        {"name": "file_path", "type": "str"}
      ],
      "output_ports": [
        {"name": "table", "type": "Any"}
      ]
    },
    {
      "id": "rag_filter",
      "type": "Filter",
      "controllable": false,
      "params": {
        "column": "score",
        "op": "ge",
        "value": "tool.rag_search.rag.min_score"
      },
      "input_ports": [
        {"name": "value", "type": "float"},
        {"name": "table", "type": "table"},
        {"name": "column", "type": "str"},
        {"name": "op", "type": "str"}
      ],
      "output_ports": [
        {"name": "row_count", "type": "float"},
        {"name": "table", "type": "table"}
      ]
    },
    {
      "id": "format_rag",
      "type": "FormatRagPrompt",
      "controllable": false,
      "params": {
        "max_chars": "tool.rag_search.rag.format_max_chars",
        "snippet_max": "tool.rag_search.rag.format_snippet_max"
      },
      "input_ports": [
        {"name": "table", "type": "Any"}
      ],
      "output_ports": [
        {"name": "data", "type": "str"}
      ]
    }
  ],
  "connections": [
    { "from": "rag_search", "to": "rag_filter", "from_port": "0", "to_port": "1" },
    { "from": "rag_filter", "to": "format_rag", "from_port": "1", "to_port": "0" }
  ],
  "metadata": {
    "description": "RAG context for chat: query (and optional file_path) → RagSearch → Filter → FormatRagPrompt. Filter/format caps use tool.rag_search.rag.* (assistants/tools/rag_search/tool.yaml); nested RunWorkflow overrides format to tool.read_file.rag.* or tool.read_code_block.rag.* (read_file_workflow / read_code_block follow-up PayloadTransform)."
  }
}
