        "required_keys": ["user_message"]
      },
      "input_ports": [
        {"name": "in_0", "type": "Any"},
        {"name": "in_1", "type": "Any"},
        {"name": "in_2", "type": "Any"},
        {"name": "in_3", "type": "Any"},
        {"name": "in_4", "type": "Any"},
        {"name": "in_5", "type": "Any"},
        {"name": "in_6", "type": "Any"},
