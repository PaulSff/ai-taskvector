        "num_inputs": 16,
        "keys": [
          "user_message",
          "graph_summary",
          "units_library",
          "rag_context",
          "turn_state",
          "recent_changes_block",
          "last_edit_block",
          "follow_up_context",
          "add_environment_edit",
          "add_code_block_edit",
          "ai_training_integration",
          "run_workflow",
          "running_flow_line",
          "debugging_line",
          "coding_line",
          "previous_turn"
