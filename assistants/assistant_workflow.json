      },
      "input_ports": [
        {"name": "data", "type": "Any"}
      ],
      "output_ports": [
        {"name": "system_prompt", "type": "str"},
        {"name": "user_message", "type": "str"}
      ]
    },
    {
      "id": "llm_agent",
      "type": "LLMAgent",
      "controllable": false,
      "params": {
        "model_name": "{settings}",
        "provider": "{settings}",
        "host": "{settings}"
      },
      "input_ports": [
        {"name": "system_prompt", "type": "str"},
        {"name": "user_message", "type": "str"}
      ],
      "output_ports": [
        {"name": "action", "type": "Any"},
        {"name": "error", "type": "str"}
      ]
    },
    {
      "id": "parser",
      "type": "ProcessAgent",
      "controllable": false,
      "params": {},
      "input_ports": [
