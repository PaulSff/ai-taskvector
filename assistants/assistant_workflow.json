{
  "units": [
    {
      "id": "inject_user_message",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "input_ports": [
        {"name": "data", "type": "Any"}
      ],
      "output_ports": [
        {"name": "data", "type": "Any"}
      ]
    },
    {
      "id": "graph_summary",
      "type": "GraphSummary",
      "controllable": false,
      "params": {},
      "input_ports": [
        {"name": "graph", "type": "Any"}
      ],
      "output_ports": [
        {"name": "summary", "type": "Any"}
      ]
    },
    {
      "id": "units_library",
      "type": "UnitsLibrary",
      "controllable": false,
      "params": {},
      "input_ports": [
        {"name": "graph_summary", "type": "Any"}
      ],
      "output_ports": [
        {"name": "data", "type": "str"}
      ]
    },
    {
      "id": "rag_search",
      "type": "RagSearch",
      "controllable": false,
      "params": {
        "persist_dir": ".rag_index",
        "embedding_model": "sentence-transformers/all-MiniLM-L6-v2",
        "top_k": 10
      },
      "input_ports": [
        {"name": "query", "type": "str"},
        {"name": "edits", "type": "Any"}
      ],
      "output_ports": [
        {"name": "table", "type": "Any"}
      ]
    },
    {
      "id": "rag_search_action",
      "type": "RagSearch",
      "controllable": false,
      "params": {
        "persist_dir": ".rag_index",
        "embedding_model": "sentence-transformers/all-MiniLM-L6-v2",
        "top_k": 10
      },
      "input_ports": [
        {"name": "query", "type": "str"},
        {"name": "edits", "type": "Any"}
      ],
      "output_ports": [
        {"name": "table", "type": "Any"}
      ]
    },
    {
      "id": "rag_filter",
      "type": "Filter",
      "controllable": false,
      "params": {
        "column": "score",
        "op": "ge",
        "value": 0.48
      },
      "input_ports": [
        {"name": "value", "type": "float"},
        {"name": "table", "type": "table"},
        {"name": "column", "type": "str"},
        {"name": "op", "type": "str"}
      ],
      "output_ports": [
        {"name": "row_count", "type": "float"},
        {"name": "table", "type": "table"}
      ]
    },
    {
      "id": "format_rag",
      "type": "FormatRagPrompt",
      "controllable": false,
      "params": {
        "max_chars": 1200,
        "snippet_max": 400
      },
      "input_ports": [
        {"name": "table", "type": "Any"}
      ],
      "output_ports": [
        {"name": "data", "type": "str"}
      ]
    },
    {
      "id": "inject_turn_state",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "input_ports": [],
      "output_ports": [
        {"name": "data", "type": "Any"}
      ]
    },
    {
      "id": "inject_recent_changes_block",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "input_ports": [],
      "output_ports": [
        {"name": "data", "type": "Any"}
      ]
    },
    {
      "id": "graph_diff",
      "type": "GraphDiff",
      "controllable": false,
      "params": {},
      "input_ports": [
        {"name": "prev_graph", "type": "Any"},
        {"name": "current_graph", "type": "Any"}
      ],
      "output_ports": [
        {"name": "diff", "type": "str"}
      ]
    },
    {
      "id": "inject_last_edit_block",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "input_ports": [],
      "output_ports": [
        {"name": "data", "type": "Any"}
      ]
    },
    {
      "id": "inject_follow_up_context",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "input_ports": [],
      "output_ports": [
        {"name": "data", "type": "Any"}
      ]
    },
    {
      "id": "inject_graph",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "input_ports": [],
      "output_ports": [
        {"name": "data", "type": "Any"}
      ]
    },
    {
      "id": "merge_llm",
      "type": "Aggregate",
      "controllable": false,
      "params": {
        "num_inputs": 8,
        "keys": [
          "user_message",
          "graph_summary",
          "units_library",
          "rag_context",
          "turn_state",
          "recent_changes_block",
          "last_edit_block",
          "follow_up_context"
        ],
        "required_keys": ["user_message"]
      },
      "input_ports": [
        {"name": "in_0", "type": "Any"},
        {"name": "in_1", "type": "Any"},
        {"name": "in_2", "type": "Any"},
        {"name": "in_3", "type": "Any"},
        {"name": "in_4", "type": "Any"},
        {"name": "in_5", "type": "Any"},
        {"name": "in_6", "type": "Any"},
        {"name": "in_7", "type": "Any"}
      ],
      "output_ports": [
        {"name": "data", "type": "Any"},
        {"name": "error", "type": "str"}
      ]
    },
    {
      "id": "prompt_llm",
      "type": "Prompt",
      "controllable": false,
      "params": {
        "template_path": "config/prompts/workflow_designer.json"
      },
      "input_ports": [
        {"name": "data", "type": "Any"}
      ],
      "output_ports": [
        {"name": "system_prompt", "type": "str"},
        {"name": "user_message", "type": "str"}
      ]
    },
    {
      "id": "llm_agent",
      "type": "LLMAgent",
      "controllable": false,
      "params": {
        "model_name": "qwen3-coder:480b-cloud",
        "provider": "ollama",
        "host": "http://127.0.0.1:11434"
      },
      "input_ports": [
        {"name": "system_prompt", "type": "str"},
        {"name": "user_message", "type": "str"}
      ],
      "output_ports": [
        {"name": "action", "type": "Any"},
        {"name": "error", "type": "str"}
      ]
    },
    {
      "id": "parser",
      "type": "ProcessAgent",
      "controllable": false,
      "params": {},
      "input_ports": [
        {"name": "action", "type": "Any"}
      ],
      "output_ports": [
        {"name": "edits", "type": "Any"},
        {"name": "error", "type": "str"}
      ]
    },
    {
      "id": "process",
      "type": "ApplyEdits",
      "controllable": false,
      "params": {},
      "input_ports": [
        {"name": "graph", "type": "Any"},
        {"name": "edits", "type": "Any"}
      ],
      "output_ports": [
        {"name": "result", "type": "Any"},
        {"name": "status", "type": "Any"},
        {"name": "graph", "type": "Any"},
        {"name": "error", "type": "str"}
      ]
    },
    {
      "id": "run_workflow",
      "type": "RunWorkflow",
      "controllable": false,
      "params": {},
      "input_ports": [
        {"name": "parser_output", "type": "Any"},
        {"name": "graph", "type": "Any"}
      ],
      "output_ports": [
        {"name": "data", "type": "Any"},
        {"name": "error", "type": "str"}
      ]
    },
    {
      "id": "merge_response",
      "type": "Aggregate",
      "controllable": false,
      "params": {
        "num_inputs": 7,
        "keys": [
          "reply",
          "result",
          "status",
          "graph",
          "diff",
          "parser_output",
          "run_output"
        ]
      },
      "input_ports": [
        {"name": "in_0", "type": "Any"},
        {"name": "in_1", "type": "Any"},
        {"name": "in_2", "type": "Any"},
        {"name": "in_3", "type": "Any"},
        {"name": "in_4", "type": "Any"},
        {"name": "in_5", "type": "Any"},
        {"name": "in_6", "type": "Any"}
      ],
      "output_ports": [
        {"name": "data", "type": "Any"}
      ]
    },
    {
      "id": "merge_errors",
      "type": "Aggregate",
      "controllable": false,
      "params": {
        "num_inputs": 4,
        "keys": ["llm_agent", "parser", "process", "run_workflow"]
      },
      "input_ports": [
        {"name": "in_0", "type": "Any"},
        {"name": "in_1", "type": "Any"},
        {"name": "in_2", "type": "Any"},
        {"name": "in_3", "type": "Any"}
      ],
      "output_ports": [
        {"name": "data", "type": "Any"}
      ]
    },
    {
      "id": "debug_errors",
      "type": "Debug",
      "controllable": false,
      "params": {
        "log_path": "log.txt"
      },
      "input_ports": [
        {"name": "data", "type": "Any"}
      ],
      "output_ports": [
        {"name": "data", "type": "Any"},
        {"name": "error", "type": "str"}
      ]
    }
  ],
  "connections": [
    { "from": "inject_user_message", "to": "merge_llm", "from_port": "0", "to_port": "0" },
    { "from": "inject_user_message", "to": "rag_search", "from_port": "0", "to_port": "0" },
    { "from": "rag_search", "to": "rag_filter", "from_port": "0", "to_port": "1" },
    { "from": "rag_filter", "to": "format_rag", "from_port": "1", "to_port": "0" },
    { "from": "format_rag", "to": "merge_llm", "from_port": "0", "to_port": "3" },
    { "from": "inject_graph", "to": "graph_summary", "from_port": "0", "to_port": "0" },
    { "from": "graph_summary", "to": "merge_llm", "from_port": "0", "to_port": "1" },
    { "from": "graph_summary", "to": "units_library", "from_port": "0", "to_port": "0" },
    { "from": "units_library", "to": "merge_llm", "from_port": "0", "to_port": "2" },
    { "from": "inject_turn_state", "to": "merge_llm", "from_port": "0", "to_port": "4" },
    { "from": "inject_graph", "to": "graph_diff", "from_port": "0", "to_port": "0" },
    { "from": "process", "to": "graph_diff", "from_port": "2", "to_port": "1" },
    { "from": "inject_recent_changes_block", "to": "merge_llm", "from_port": "0", "to_port": "5" },
    { "from": "inject_last_edit_block", "to": "merge_llm", "from_port": "0", "to_port": "6" },
    { "from": "inject_follow_up_context", "to": "merge_llm", "from_port": "0", "to_port": "7" },
    { "from": "inject_graph", "to": "process", "from_port": "0", "to_port": "0" },
    { "from": "merge_llm", "to": "prompt_llm", "from_port": "0", "to_port": "0" },
    { "from": "prompt_llm", "to": "llm_agent", "from_port": "0", "to_port": "0" },
    { "from": "prompt_llm", "to": "llm_agent", "from_port": "1", "to_port": "1" },
    { "from": "llm_agent", "to": "parser", "from_port": "0", "to_port": "0" },
    { "from": "parser", "to": "process", "from_port": "0", "to_port": "1" },
    { "from": "parser", "to": "rag_search_action", "from_port": "0", "to_port": "1" },
    { "from": "parser", "to": "run_workflow", "from_port": "0", "to_port": "0" },
    { "from": "inject_graph", "to": "run_workflow", "from_port": "0", "to_port": "1" },
    { "from": "llm_agent", "to": "merge_response", "from_port": "0", "to_port": "0" },
    { "from": "process", "to": "merge_response", "from_port": "0", "to_port": "1" },
    { "from": "process", "to": "merge_response", "from_port": "1", "to_port": "2" },
    { "from": "process", "to": "merge_response", "from_port": "2", "to_port": "3" },
    { "from": "graph_diff", "to": "merge_response", "from_port": "0", "to_port": "4" },
    { "from": "parser", "to": "merge_response", "from_port": "0", "to_port": "5" },
    { "from": "run_workflow", "to": "merge_response", "from_port": "0", "to_port": "6" },
    { "from": "llm_agent", "to": "merge_errors", "from_port": "1", "to_port": "0" },
    { "from": "parser", "to": "merge_errors", "from_port": "1", "to_port": "1" },
    { "from": "process", "to": "merge_errors", "from_port": "3", "to_port": "2" },
    { "from": "run_workflow", "to": "merge_errors", "from_port": "1", "to_port": "3" },
    { "from": "merge_errors", "to": "debug_errors", "from_port": "0", "to_port": "0" }
  ]
}
