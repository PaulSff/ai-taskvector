{
  "units": [
    {
      "id": "inject_user_message",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "input_ports": [
        {"name": "data", "type": "Any"}
      ],
      "output_ports": [
        {"name": "data", "type": "Any"}
      ]
    },
    {
      "id": "graph_summary",
      "type": "GraphSummary",
      "controllable": false,
      "params": {},
      "input_ports": [
        {"name": "graph", "type": "Any"}
      ],
      "output_ports": [
        {"name": "summary", "type": "Any"}
      ]
    },
    {
      "id": "units_library",
      "type": "UnitsLibrary",
      "controllable": false,
      "params": {},
      "input_ports": [
        {"name": "graph_summary", "type": "Any"}
      ],
      "output_ports": [
        {"name": "data", "type": "str"}
      ]
    },
    {
      "id": "rag_search",
      "type": "RagSearch",
      "controllable": false,
      "params": {
        "persist_dir": "{settings}",
        "embedding_model": "{settings}",
        "top_k": 10
      },
      "input_ports": [
        {"name": "query", "type": "str"},
        {"name": "edits", "type": "Any"}
      ],
      "output_ports": [
        {"name": "table", "type": "Any"}
      ]
    },
    {
      "id": "rag_filter",
      "type": "Filter",
      "controllable": false,
      "params": {
        "column": "score",
        "op": "ge",
        "value": 0.48
      },
      "input_ports": [
        {"name": "value", "type": "float"},
        {"name": "table", "type": "table"},
        {"name": "column", "type": "str"},
        {"name": "op", "type": "str"}
      ],
      "output_ports": [
        {"name": "row_count", "type": "float"},
        {"name": "table", "type": "table"}
      ]
    },
    {
      "id": "format_rag",
      "type": "FormatRagPrompt",
      "controllable": false,
      "params": {
        "max_chars": 1200,
        "snippet_max": 400
      },
      "input_ports": [
        {"name": "table", "type": "Any"}
      ],
      "output_ports": [
        {"name": "data", "type": "str"}
      ]
    },
    {
      "id": "inject_turn_state",
