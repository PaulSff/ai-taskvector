      "output_ports": [
        {"name": "origin", "type": "str"},
        {"name": "graph", "type": "Any"},
        {"name": "error", "type": "str"}
      ]
    },
    {
      "id": "process",
      "type": "ApplyEdits",
      "controllable": false,
      "params": {},
      "input_ports": [
        {"name": "graph", "type": "Any"},
        {"name": "edits", "type": "Any"},
        {"name": "graph_origin", "type": "str"}
      ],
      "output_ports": [
        {"name": "result", "type": "Any"},
        {"name": "status", "type": "Any"},
        {"name": "graph", "type": "Any"},
        {"name": "error", "type": "str"}
      ]
    },
    {
      "id": "report",
      "type": "Report",
      "controllable": false,
      "params": {
        "output_dir": "{settings}"
      },
      "input_ports": [
        {"name": "parser_output", "type": "Any"}
      ],
      "output_ports": [
        {"name": "data", "type": "Any"},
        {"name": "error", "type": "str"}
      ]
    },
    {
      "id": "run_workflow",
      "type": "RunWorkflow",
      "controllable": false,
      "params": {},
      "input_ports": [
        {"name": "parser_output", "type": "Any"},
        {"name": "graph", "type": "Any"}
      ],
      "output_ports": [
        {"name": "data", "type": "Any"},
        {"name": "error", "type": "str"}
      ]
    },
    {
      "id": "grep",
      "type": "grep",
      "controllable": false,
      "params": {},
      "input_ports": [
        {"name": "in", "type": "Any"},
        {"name": "parser_output", "type": "Any"}
      ],
      "output_ports": [
        {"name": "out", "type": "Any"},
        {"name": "error", "type": "str"}
      ]
    },
    {
      "id": "merge_response",
      "type": "Aggregate",
      "controllable": false,
      "params": {
        "num_inputs": 9,
        "keys": [
          "reply",
          "result",
          "status",
          "graph",
          "diff",
          "parser_output",
          "run_output",
          "report_output",
          "grep_output"
        ]
      },
      "input_ports": [
        {"name": "in_0", "type": "Any"},
        {"name": "in_1", "type": "Any"},
        {"name": "in_2", "type": "Any"},
        {"name": "in_3", "type": "Any"},
        {"name": "in_4", "type": "Any"},
        {"name": "in_5", "type": "Any"},
        {"name": "in_6", "type": "Any"},
        {"name": "in_7", "type": "Any"},
        {"name": "in_8", "type": "Any"}
      ],
      "output_ports": [
        {"name": "data", "type": "Any"}
      ]
    },
    {
      "id": "merge_errors",
      "type": "Aggregate",
      "controllable": false,
      "params": {
        "num_inputs": 6,
        "keys": ["llm_agent", "parser", "process", "run_workflow", "report", "grep"]
      },
      "input_ports": [
        {"name": "in_0", "type": "Any"},
        {"name": "in_1", "type": "Any"},
        {"name": "in_2", "type": "Any"},
        {"name": "in_3", "type": "Any"},
        {"name": "in_4", "type": "Any"},
        {"name": "in_5", "type": "Any"}
      ],
      "output_ports": [
        {"name": "data", "type": "Any"}
      ]
    },
