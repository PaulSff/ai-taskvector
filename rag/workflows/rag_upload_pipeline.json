{
  "units": [
    {
      "id": "fetch_source",
      "type": "FetchSource",
      "controllable": false,
      "params": {
        "save_dir": "settings.rag_downloads_dir",
        "overwrite": false
      },
      "input_ports": [
        {
          "name": "source",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "file_path",
          "type": "str"
        },
        {
          "name": "source",
          "type": "str"
        },
        {
          "name": "fetched",
          "type": "Any"
        },
        {
          "name": "error",
          "type": "str"
        }
      ]
    },
    {
      "id": "inject_path",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "input_ports": [
        {
          "name": "template",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "data",
          "type": "Any"
        }
      ]
    },
    {
      "id": "detect",
      "type": "FileTypeDetector",
      "controllable": false,
      "params": {},
      "input_ports": [
        {
          "name": "data",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "content_type_id",
          "type": "str"
        },
        {
          "name": "content_kind",
          "type": "str"
        },
        {
          "name": "family",
          "type": "str"
        },
        {
          "name": "suffix",
          "type": "str"
        },
        {
          "name": "payload",
          "type": "Any"
        },
        {
          "name": "parsed",
          "type": "Any"
        },
        {
          "name": "error",
          "type": "str"
        }
      ]
    },
    {
      "id": "pt_run",
      "type": "PayloadTransform",
      "controllable": false,
      "params": {
        "routes": [
          {
            "any": [
              {
                "field": "suffix",
                "ends_with": ".json"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/json/json_kind_index_extract.json",
                "initial_inputs": {
                  "inject_path": {
                    "data": "{file_path}"
                  }
                }
              }
            }
          },
          {
            "any": [
              {
                "field": "suffix",
                "ends_with": ".yaml"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/json/json_kind_index_extract.json",
                "initial_inputs": {
                  "inject_path": {
                    "data": "{file_path}"
                  }
                }
              }
            }
          },
          {
            "any": [
              {
                "field": "suffix",
                "ends_with": ".yml"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/json/json_kind_index_extract.json",
                "initial_inputs": {
                  "inject_path": {
                    "data": "{file_path}"
                  }
                }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "pdf-generic"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/pdf/pdf-generic/pdf_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              { "field": "content_type_id", "equals_str": "word-generic" }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/word/word-generic/word_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "spreadsheet-generic"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/spreadsheet/spreadsheet-generic/spreadsheet_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "presentation-generic"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/presentation/presentation-generic/presentation_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              { "field": "content_type_id", "equals_str": "html-generic" }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/html/html-generic/html_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "markdown-generic"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/markdown/markdown-generic/markdown_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-content-type-readme"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/markdown/taskvector-content-type-readme/content_type_readme_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-docs"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/markdown/taskvector-docs/taskvector_docs_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-rag-readme"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/markdown/taskvector-rag-readme/rag_readme_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-role-readme"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/markdown/taskvector-role-readme/role_readme_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-tool-readme"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/markdown/taskvector-tool-readme/tool_readme_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-unit-readme"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/markdown/taskvector-unit-readme/unit_readme_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "plain-text-generic"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/plain-text/plain-text-generic/plain_text_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-content-type-config"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/plain-text/taskvector-content-type-config/content_type_config.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-rag-config"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/plain-text/taskvector-rag-config/rag_config_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-role-config"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/plain-text/taskvector-role-config/role_config_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-tool-config"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/plain-text/taskvector-tool-config/tool_config_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-role-source"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/plain-text/taskvector-role-source/role_source_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-tool-source"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/plain-text/taskvector-tool-source/tool_source_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-unit-source"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/plain-text/taskvector-unit-source/unit_source_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-content-type-source"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/plain-text/taskvector-content-type-source/content_type_source_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-core-source"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/plain-text/taskvector-core-source/core_source_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-environments-source"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/plain-text/environments-source/environments_source_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-gui-source"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/plain-text/gui-source/gui_source_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-llm-integrations-source"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/plain-text/llm-integrations-source/llm_integrations_source_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-rag-source"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/plain-text/taskvector-rag-source/rag_source_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "all": [
              {
                "field": "content_type_id",
                "equals_str": "taskvector-runtime-source"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/plain-text/taskvector-runtime-source/runtime_source_extract.json",
                "initial_inputs": { "inject_path": { "data": "{file_path}" } }
              }
            }
          },
          {
            "default": true,
            "parser_output": {}
          }
        ]
      },
      "input_ports": [
        {
          "name": "data",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "parser_output",
          "type": "Any"
        }
      ]
    },
    {
      "id": "rw_run",
      "type": "RunWorkflow",
      "controllable": false,
      "params": {
        "_needs_executor": true
      },
      "input_ports": [
        {
          "name": "parser_output",
          "type": "Any"
        },
        {
          "name": "graph",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "data",
          "type": "Any"
        },
        {
          "name": "error",
          "type": "str"
        }
      ]
    },
    {
      "id": "flat_chunks",
      "type": "RagFlattenChunks",
      "controllable": false,
      "params": {},
      "input_ports": [
        {
          "name": "data",
          "type": "Any"
        },
        {
          "name": "file_path_meta",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "texts",
          "type": "Any"
        },
        {
          "name": "metadatas",
          "type": "Any"
        },
        {
          "name": "extracted",
          "type": "Any"
        },
        {
          "name": "error",
          "type": "str"
        }
      ]
    },
    {
      "id": "rbd_build",
      "type": "RagBuildIndexDocument",
      "controllable": false,
      "params": {
        "text_template": "{text}",
        "metadata_keys": ["file_path", "chunk_count"],
        "static_metadata": {
          "origin": "rag_upload"
        }
      },
      "input_ports": [
        {
          "name": "extracted",
          "type": "Any"
        },
        {
          "name": "file_path",
          "type": "str"
        },
        {
          "name": "chunk_texts",
          "type": "Any"
        },
        {
          "name": "chunk_metadatas",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "text",
          "type": "str"
        },
        {
          "name": "metadata",
          "type": "Any"
        },
        {
          "name": "document",
          "type": "Any"
        },
        {
          "name": "error",
          "type": "str"
        },
        {
          "name": "chunk_texts",
          "type": "Any"
        },
        {
          "name": "chunk_metadatas",
          "type": "Any"
        }
      ]
    },
    {
      "id": "emb",
      "type": "Embedder",
      "controllable": false,
      "params": {
        "model_name": "settings.rag_embedding_model"
      },
      "input_ports": [
        {
          "name": "texts",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "embeddings",
          "type": "Any"
        }
      ]
    },
    {
      "id": "chroma",
      "type": "ChromaIndexer",
      "controllable": false,
      "params": {
        "persist_dir": "settings.rag_index_data_dir",
        "embedding_model": "settings.rag_embedding_model"
      },
      "input_ports": [
        {
          "name": "texts",
          "type": "Any"
        },
        {
          "name": "metadatas",
          "type": "Any"
        },
        {
          "name": "embeddings",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "count",
          "type": "float"
        }
      ]
    }
  ],
  "connections": [
    {
      "from": "inject_path",
      "to": "fetch_source",
      "from_port": "0",
      "to_port": "0"
    },
    {
      "from": "fetch_source",
      "to": "detect",
      "from_port": "0",
      "to_port": "0"
    },
    {
      "from": "detect",
      "to": "pt_run",
      "from_port": "4",
      "to_port": "0"
    },
    {
      "from": "pt_run",
      "to": "rw_run",
      "from_port": "0",
      "to_port": "0"
    },
    {
      "from": "rw_run",
      "to": "flat_chunks",
      "from_port": "0",
      "to_port": "0"
    },
    {
      "from": "flat_chunks",
      "to": "rbd_build",
      "from_port": "2",
      "to_port": "0"
    },
    {
      "from": "flat_chunks",
      "to": "rbd_build",
      "from_port": "0",
      "to_port": "2"
    },
    {
      "from": "flat_chunks",
      "to": "rbd_build",
      "from_port": "1",
      "to_port": "3"
    },
    {
      "from": "rbd_build",
      "to": "emb",
      "from_port": "4",
      "to_port": "0"
    },
    {
      "from": "rbd_build",
      "to": "chroma",
      "from_port": "4",
      "to_port": "0"
    },
    {
      "from": "rbd_build",
      "to": "chroma",
      "from_port": "5",
      "to_port": "1"
    },
    {
      "from": "emb",
      "to": "chroma",
      "from_port": "0",
      "to_port": "2"
    }
  ],
  "metadata": {
    "description": "TaskVector RAG Upload workflow - the main upload workflow, which takes a file on import for its classificaton, content extraction, chunking, embeddeding and getting indexed on ChromaDB. Content gets extracted by extraction subflows, depending on the file_type detected. The subflows as well as discriminants are part of the content_type packages. The routes are defined in the PayloadTransform params."
  }
}
