{
  "units": [
    {
      "id": "inject_path",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "input_ports": [{"name": "template", "type": "Any"}],
      "output_ports": [{"name": "data", "type": "Any"}]
    },
    {
      "id": "detect",
      "type": "FileTypeDetector",
      "controllable": false,
      "params": {},
      "input_ports": [{"name": "data", "type": "Any"}],
      "output_ports": [
        {"name": "content_type_id", "type": "str"},
        {"name": "json_kind", "type": "str"},
        {"name": "suffix", "type": "str"},
        {"name": "payload", "type": "Any"},
        {"name": "parsed", "type": "Any"},
        {"name": "error", "type": "str"}
      ]
    },
    {
      "id": "pt_run",
      "type": "PayloadTransform",
      "controllable": false,
      "params": {
        "routes": [
          {
            "any": [{"field": "suffix", "ends_with": ".json"}],
            "parser_output": {
              "run_workflow": {
                "path": "rag/workflows/json_kind_index_extract.json",
                "initial_inputs": {
                  "inject_path": {"data": "{file_path}"}
                }
              }
            }
          },
          {
            "default": true,
            "parser_output": {}
          }
        ]
      },
      "input_ports": [{"name": "data", "type": "Any"}],
      "output_ports": [{"name": "parser_output", "type": "Any"}]
    },
    {
      "id": "rw_run",
      "type": "RunWorkflow",
      "controllable": false,
      "params": {},
      "input_ports": [
        {"name": "parser_output", "type": "Any"},
        {"name": "graph", "type": "Any"}
      ],
      "output_ports": [{"name": "data", "type": "Any"}, {"name": "error", "type": "str"}]
    },
    {
      "id": "flat_chunks",
      "type": "RagFlattenChunks",
      "controllable": false,
      "params": {},
      "input_ports": [
        {"name": "data", "type": "Any"},
        {"name": "file_path_meta", "type": "Any"}
      ],
      "output_ports": [
        {"name": "texts", "type": "Any"},
        {"name": "metadatas", "type": "Any"},
        {"name": "extracted", "type": "Any"},
        {"name": "error", "type": "str"}
      ]
    },
    {
      "id": "rbd_build",
      "type": "RagBuildIndexDocument",
      "controllable": false,
      "params": {
        "text_template": "{body}",
        "metadata_keys": ["file_path", "chunk_count"],
        "static_metadata": {"origin": "rag_upload"}
      },
      "input_ports": [
        {"name": "extracted", "type": "Any"},
        {"name": "file_path", "type": "str"},
        {"name": "chunk_texts", "type": "Any"},
        {"name": "chunk_metadatas", "type": "Any"}
      ],
      "output_ports": [
        {"name": "text", "type": "str"},
        {"name": "metadata", "type": "Any"},
        {"name": "document", "type": "Any"},
        {"name": "error", "type": "str"},
        {"name": "chunk_texts", "type": "Any"},
        {"name": "chunk_metadatas", "type": "Any"}
      ]
    },
    {
      "id": "emb",
      "type": "Embedder",
      "controllable": false,
      "params": {"model_name": "settings.rag_embedding_model"},
      "input_ports": [{"name": "texts", "type": "Any"}],
      "output_ports": [{"name": "embeddings", "type": "Any"}]
    },
    {
      "id": "chroma",
      "type": "ChromaIndexer",
      "controllable": false,
      "params": {
        "persist_dir": "settings.rag_index_data_dir",
        "embedding_model": "settings.rag_embedding_model"
      },
      "input_ports": [
        {"name": "texts", "type": "Any"},
        {"name": "metadatas", "type": "Any"},
        {"name": "embeddings", "type": "Any"}
      ],
      "output_ports": [{"name": "count", "type": "float"}]
    }
  ],
  "connections": [
    {"from": "inject_path", "to": "detect", "from_port": "0", "to_port": "0"},
    {"from": "detect", "to": "pt_run", "from_port": "3", "to_port": "0"},
    {"from": "pt_run", "to": "rw_run", "from_port": "0", "to_port": "0"},
    {"from": "rw_run", "to": "flat_chunks", "from_port": "0", "to_port": "0"},
    {"from": "flat_chunks", "to": "rbd_build", "from_port": "2", "to_port": "0"},
    {"from": "flat_chunks", "to": "rbd_build", "from_port": "0", "to_port": "2"},
    {"from": "flat_chunks", "to": "rbd_build", "from_port": "1", "to_port": "3"},
    {"from": "rbd_build", "to": "emb", "from_port": "4", "to_port": "0"},
    {"from": "rbd_build", "to": "chroma", "from_port": "4", "to_port": "0"},
    {"from": "rbd_build", "to": "chroma", "from_port": "5", "to_port": "1"},
    {"from": "emb", "to": "chroma", "from_port": "0", "to_port": "2"}
  ],
  "metadata": {
    "description": "Upload RAG: inject_path → FileTypeDetector (registry payload: content_type_id, json_kind, suffix, file_path) → PayloadTransform (run json_kind_index_extract when suffix ends_with .json; else no run_workflow) → RunWorkflow → RagFlattenChunks → RagBuildIndexDocument → Embedder → ChromaIndexer. Add PayloadTransform routes keyed on payload fields (e.g. content_type_id) when content_type.yaml defines extraction workflows for non-JSON types."
  }
}
