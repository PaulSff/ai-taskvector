{
  "environment_type": "rag",
  "environments": ["canonical", "rag"],
  "units": [
    {
      "id": "inject_path",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "name": null,
      "input_ports": [
        {
          "name": "template",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "data",
          "type": "Any"
        }
      ]
    },
    {
      "id": "rag_detect",
      "type": "RagDetectOrigin",
      "controllable": false,
      "params": {},
      "name": null,
      "input_ports": [
        {
          "name": "graph",
          "type": "Any"
        },
        {
          "name": "path",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "origin",
          "type": "str"
        },
        {
          "name": "graph",
          "type": "Any"
        },
        {
          "name": "error",
          "type": "str"
        },
        {
          "name": "context",
          "type": "Any"
        }
      ]
    },
    {
      "id": "rw_kind_run",
      "type": "RunWorkflow",
      "controllable": true,
      "params": {},
      "name": null,
      "input_ports": [
        {
          "name": "parser_output",
          "type": "Any"
        },
        {
          "name": "graph",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "data",
          "type": "Any"
        },
        {
          "name": "error",
          "type": "str"
        }
      ]
    },
    {
      "id": "chunk_builder",
      "type": "RagChunkBuilder",
      "controllable": false,
      "params": {},
      "name": null,
      "input_ports": [
        {
          "name": "items",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "chunks",
          "type": "Any"
        },
        {
          "name": "error",
          "type": "str"
        }
      ]
    },
    {
      "id": "pt_kind_route",
      "type": "PayloadTransform",
      "controllable": true,
      "params": {
        "routes": [
          {
            "any": [
              {
                "field": "origin",
                "equals_str": "chat_history"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/json/chat-history/chat_history.json",
                "initial_inputs": {
                  "extractor": {
                    "data": {
                      "_raw": "parsed"
                    },
                    "file_path": "{file_path}"
                  }
                }
              }
            }
          },
          {
            "any": [
              {
                "field": "origin",
                "equals_str": "canonical"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/json/taskvector-workflow/canonical.json",
                "initial_inputs": {
                  "extractor": {
                    "data": {
                      "file_path": "{file_path}",
                      "parsed": "{parsed}",
                      "origin": "{origin}"
                    },
                    "file_path": "{file_path}"
                  }
                }
              }
            }
          },
          {
            "any": [
              {
                "field": "origin",
                "equals_str": "node_red"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/json/node-red-workflow/node_red.json",
                "initial_inputs": {
                  "extractor": {
                    "data": {
                      "file_path": "{file_path}",
                      "parsed": "{parsed}",
                      "origin": "{origin}"
                    },
                    "file_path": "{file_path}"
                  }
                }
              }
            }
          },
          {
            "any": [
              {
                "field": "origin",
                "equals_str": "n8n"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/json/n8n-workflow/n8n.json",
                "initial_inputs": {
                  "extractor": {
                    "data": {
                      "file_path": "{file_path}",
                      "parsed": "{parsed}",
                      "origin": "{origin}"
                    },
                    "file_path": "{file_path}"
                  }
                }
              }
            }
          },
          {
            "any": [
              {
                "field": "origin",
                "equals_str": "json-generic"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/json/json-generic/generic.json",
                "initial_inputs": {
                  "extractor": {
                    "data": [
                      {
                        "file_path": "{file_path}",
                        "parsed": "{parsed}",
                        "origin": "{origin}"
                      }
                    ],
                    "file_path": "{file_path}"
                  }
                }
              }
            }
          },
          {
            "any": [
              {
                "field": "origin",
                "equals_str": "taskvector-content-type-config"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/json/taskvector-content-type-config/content_type_config_extract.json",
                "initial_inputs": {
                  "extractor": {
                    "data": [
                      {
                        "file_path": "{file_path}",
                        "parsed": "{parsed}",
                        "origin": "{origin}"
                      }
                    ],
                    "file_path": "{file_path}"
                  }
                }
              }
            }
          },
          {
            "any": [
              {
                "field": "origin",
                "equals_str": "taskvector-rag-config"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/json/taskvector-rag-config/rag_config_extract.json",
                "initial_inputs": {
                  "extractor": {
                    "data": [
                      {
                        "file_path": "{file_path}",
                        "parsed": "{parsed}",
                        "origin": "{origin}"
                      }
                    ],
                    "file_path": "{file_path}"
                  }
                }
              }
            }
          },
          {
            "any": [
              {
                "field": "origin",
                "equals_str": "taskvector-role-config"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/json/taskvector-role-config/role_config_extract.json",
                "initial_inputs": {
                  "extractor": {
                    "data": [
                      {
                        "file_path": "{file_path}",
                        "parsed": "{parsed}",
                        "origin": "{origin}"
                      }
                    ],
                    "file_path": "{file_path}"
                  }
                }
              }
            }
          },
          {
            "any": [
              {
                "field": "origin",
                "equals_str": "taskvector-tool-config"
              }
            ],
            "parser_output": {
              "run_workflow": {
                "path": "rag/content_types/json/taskvector-tool-config/tool_config_extract.json",
                "initial_inputs": {
                  "extractor": {
                    "data": [
                      {
                        "file_path": "{file_path}",
                        "parsed": "{parsed}",
                        "origin": "{origin}"
                      }
                    ],
                    "file_path": "{file_path}"
                  }
                }
              }
            }
          }
        ]
      },
      "name": null,
      "input_ports": [
        {
          "name": "data",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "parser_output",
          "type": "Any"
        }
      ]
    },
    {
      "id": "pt_extract_items",
      "type": "PayloadTransform",
      "controllable": true,
      "params": {
        "repeat_for_each": {
          "field": "extractor.items",
          "merge_key": "item",
          "output_key": "items",
          "item_template": {
            "text": "{item.text}",
            "metadata": "{item.metadata}"
          }
        },
        "routes": [
          {
            "any": [
              {
                "field": "extractor",
                "contains": "items"
              }
            ],
            "parser_output": {
              "items": "{items}"
            }
          }
        ]
      },
      "name": null,
      "input_ports": [
        {
          "name": "data",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "parser_output",
          "type": "Any"
        }
      ]
    }
  ],
  "connections": [
    {
      "from": "inject_path",
      "to": "rag_detect",
      "from_port": "0",
      "to_port": "1",
      "connection_type": null
    },
    {
      "from": "rag_detect",
      "to": "pt_kind_route",
      "from_port": "3",
      "to_port": "0",
      "connection_type": null
    },
    {
      "from": "pt_kind_route",
      "to": "rw_kind_run",
      "from_port": "0",
      "to_port": "0",
      "connection_type": null
    },
    {
      "from": "pt_extract_items",
      "to": "chunk_builder",
      "from_port": "0",
      "to_port": "0",
      "connection_type": null
    },
    {
      "from": "rw_kind_run",
      "to": "pt_extract_items",
      "from_port": "0",
      "to_port": "0",
      "connection_type": null
    }
  ],
  "code_blocks": [],
  "origin": {
    "canonical": true,
    "node_red": null,
    "pyflow": null,
    "n8n": null,
    "ryven": null,
    "comfyui": null
  },
  "origin_format": "dict",
  "runtime": "native",
  "tabs": null,
  "metadata": {
    "description": "Routes JSON content types through the PayloadTransform to dedicated extraction paths. Workflow types (chat_history, canonical, node_red, n8n) use specialised extractors; everything else (including generic JSON) goes through JsonFlattenExtract which recursively flattens any JSON into searchable key:value text. All paths end at a RagChunkBuilder."
  }
}
