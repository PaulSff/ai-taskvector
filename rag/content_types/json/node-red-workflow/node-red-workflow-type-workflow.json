{
  "units": [
    {
      "id": "inject_json",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "input_ports": [{"name": "template", "type": "Any"}],
      "output_ports": [{"name": "data", "type": "Any"}]
    },
    {
      "id": "inject_path",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "input_ports": [{"name": "template", "type": "Any"}],
      "output_ports": [{"name": "data", "type": "Any"}]
    },
    {
      "id": "parse",
      "type": "JsonParser",
      "controllable": false,
      "params": {"wrap_top_level_list": true},
      "input_ports": [{"name": "data", "type": "Any"}],
      "output_ports": [
        {"name": "parsed", "type": "Any"},
        {"name": "file_path", "type": "str"},
        {"name": "error", "type": "str"}
      ]
    },
    {
      "id": "merge_ctx",
      "type": "Aggregate",
      "controllable": false,
      "params": {"num_inputs": 2, "keys": ["graph", "file_path"]},
      "input_ports": [
        {"name": "data", "type": "Any"},
        {"name": "in_0", "type": "Any"},
        {"name": "in_1", "type": "Any"}
      ],
      "output_ports": [{"name": "data", "type": "Any"}, {"name": "error", "type": "str"}]
    },
    {
      "id": "extract",
      "type": "RagExtract",
      "controllable": false,
      "params": {
        "paths": [
          {"out": "file_path", "from": "file_path"},
          {"out": "format", "constant": "node_red"}
        ]
      },
      "input_ports": [{"name": "data", "type": "Any"}],
      "output_ports": [{"name": "extracted", "type": "Any"}, {"name": "error", "type": "str"}]
    },
    {
      "id": "build_doc",
      "type": "RagBuildIndexDocument",
      "controllable": false,
      "params": {
        "text_template": "Node-RED workflow JSON at {file_path}",
        "metadata_keys": ["format", "file_path"],
        "static_metadata": {"content_type": "workflow", "origin": "node-red"}
      },
      "input_ports": [
        {"name": "extracted", "type": "Any"},
        {"name": "file_path", "type": "str"}
      ],
      "output_ports": [
        {"name": "text", "type": "str"},
        {"name": "metadata", "type": "Any"},
        {"name": "document", "type": "Any"},
        {"name": "error", "type": "str"}
      ]
    }
  ],
  "connections": [
    {"from": "inject_json", "to": "parse", "from_port": "0", "to_port": "0"},
    {"from": "parse", "to": "merge_ctx", "from_port": "0", "to_port": "1"},
    {"from": "inject_path", "to": "merge_ctx", "from_port": "0", "to_port": "2"},
    {"from": "merge_ctx", "to": "extract", "from_port": "0", "to_port": "0"},
    {"from": "extract", "to": "build_doc", "from_port": "0", "to_port": "0"},
    {"from": "inject_path", "to": "build_doc", "from_port": "0", "to_port": "1"}
  ],
  "metadata": {
    "description": "Declarative stub: inject JSON + path → parse → merge → extract file_path → build one RAG row. Extend RagExtract paths for rich metadata."
  }
}
