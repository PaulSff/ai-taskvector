    {
      "id": "format_doc",
      "type": "PayloadTransform",
      "controllable": false,
      "params": {
        "routes": [
          {
            "default": true,
            "parser_output": {
              "items": [
                {
                  "text": "{body_text}\n\n{markdown}\n\n{tables_text}\n\n{pictures}n\n{headings}n\n{furniture}",
                  "metadata": {
                    "file_path": "{file_path}",
                    "page_count": "{page_count}",
                    "content_type": "document",
                    "origin": "pdf"
                  }
                }
              ]
            }
          }
        ]
      },
      "name": null,
      "input_ports": [
        {
          "name": "data",
          "type": "Any"
        }
      ],
      "output_ports": [
        {
          "name": "parser_output",
          "type": "Any"
        }
      ]
    },
    {
      "id": "merge",
      "type": "Aggregate",
      "controllable": false,
      "params": {
        "num_inputs": 8,
