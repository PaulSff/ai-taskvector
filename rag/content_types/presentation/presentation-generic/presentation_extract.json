{
  "environment_type": "rag",
  "environments": ["canonical", "rag"],
  "units": [
    {
      "id": "inject_path",
      "type": "Inject",
      "controllable": false,
      "params": {},
      "input_ports": [{ "name": "template", "type": "Any" }],
      "output_ports": [{ "name": "data", "type": "Any" }]
    },
    {
      "id": "load_doc",
      "type": "LoadDocument",
      "controllable": false,
      "params": {
        "include_pictures": "settings.rag_include_pictures",
        "images_scale": "settings.rag_images_scale",
        "do_picture_classification": "settings.rag_picture_classification",
        "do_picture_description": "settings.rag_picture_description",
        "picture_description_model": "settings.rag_picture_description_model",
        "picture_description_api_url": "settings.rag_picture_description_api_url",
        "do_code_enrichment": "settings.rag_code_enrichment",
        "do_formula_enrichment": "settings.rag_formula_enrichment"
      },
      "name": null,
      "input_ports": [
        {
          "name": "path",
          "type": "str"
        }
      ],
      "output_ports": [
        {
          "name": "body_text",
          "type": "str"
        },
        {
          "name": "markdown",
          "type": "str"
        },
        {
          "name": "html",
          "type": "str"
        },
        {
          "name": "doctags",
          "type": "str"
        },
        {
          "name": "json_doc",
          "type": "Any"
        },
        {
          "name": "tables",
          "type": "Any"
        },
        {
          "name": "pictures",
          "type": "Any"
        },
        {
          "name": "headings",
          "type": "Any"
        },
        {
          "name": "furniture",
          "type": "Any"
        },
        {
          "name": "key_value_items",
          "type": "Any"
        },
        {
          "name": "page_count",
          "type": "float"
        },
        {
          "name": "error",
          "type": "str"
        }
      ]
    },
    {
      "id": "tables_to_text",
      "type": "TablesToText",
      "controllable": false,
      "params": { "format": "csv" },
      "input_ports": [{ "name": "tables", "type": "Any" }],
      "output_ports": [
        { "name": "text", "type": "str" },
        { "name": "row_count", "type": "float" }
      ]
    },
    {
      "id": "merge",
      "type": "Aggregate",
      "controllable": false,
      "params": {
        "num_inputs": 5,
        "keys": ["body", "tables_text", "file_path", "page_count", "pictures"]
      },
      "input_ports": [
        { "name": "data", "type": "Any" },
        { "name": "in_0", "type": "Any" },
        { "name": "in_1", "type": "Any" },
        { "name": "in_2", "type": "Any" },
        { "name": "in_3", "type": "Any" },
        { "name": "in_4", "type": "Any" }
      ],
      "output_ports": [
        { "name": "data", "type": "Any" },
        { "name": "error", "type": "str" }
      ]
    },
    {
      "id": "format_doc",
      "type": "PayloadTransform",
      "controllable": false,
      "params": {
        "routes": [
          {
            "default": true,
            "parser_output": {
              "items": [
                {
                  "text": "{body}\n\nTables:\n{tables_text}\n\nPictures:\n{pictures}",
                  "metadata": {
                    "file_path": "{file_path}",
                    "page_count": "{page_count}",
                    "content_type": "presentation-generic",
                    "origin": "external-upload"
                  }
                }
              ]
            }
          }
        ]
      },
      "input_ports": [{ "name": "data", "type": "Any" }],
      "output_ports": [{ "name": "parser_output", "type": "Any" }]
    },
    {
      "id": "chunk_builder",
      "type": "RagChunkBuilder",
      "controllable": false,
      "params": {},
      "input_ports": [{ "name": "items", "type": "Any" }],
      "output_ports": [
        { "name": "chunks", "type": "Any" },
        { "name": "error", "type": "str" }
      ]
    }
  ],
  "connections": [
    {
      "from": "inject_path",
      "to": "load_doc",
      "from_port": "0",
      "to_port": "0"
    },
    {
      "from": "inject_path",
      "to": "merge",
      "from_port": "0",
      "to_port": "3"
    },
    {
      "from": "load_doc",
      "to": "merge",
      "from_port": "0",
      "to_port": "1"
    },
    {
      "from": "load_doc",
      "to": "merge",
      "from_port": "10",
      "to_port": "4"
    },
    {
      "from": "load_doc",
      "to": "merge",
      "from_port": "6",
      "to_port": "5"
    },
    {
      "from": "load_doc",
      "to": "tables_to_text",
      "from_port": "5",
      "to_port": "0"
    },
    {
      "from": "tables_to_text",
      "to": "merge",
      "from_port": "0",
      "to_port": "2"
    },
    {
      "from": "merge",
      "to": "format_doc",
      "from_port": "0",
      "to_port": "0"
    },
    {
      "from": "format_doc",
      "to": "chunk_builder",
      "from_port": "0",
      "to_port": "0"
    }
  ],
  "metadata": {
    "description": "Presentation extraction subflow: This workflow extracts valuable data from ppt/pptx presentation documents via Docling (body text, tables, pictures description, page count, file path) and outputs chunks for rag_upload_pipeline."
  }
}
